umlah_stok\n\nFROM raw_inventory\nWHERE id IS NOT NULL AND id != ''", "relation_name": "`kba_silver`.`silver_inventory`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-25T13:16:54.707562Z", "completed_at": "2026-04-25T13:16:54.761472Z"}, {"name": "execute", "started_at": "2026-04-25T13:16:54.764386Z", "completed_at": "2026-04-25T13:16:55.159927Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.4658079147338867, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.kba_kelompok_7.silver_purchase", "compiled": true, "compiled_code": "\n\nWITH raw_purchase AS (\n    SELECT * FROM kba_bronze.purchase_order\n)\n\nSELECT\n    toInt32OrNull(id) AS id_pembelian,\n    name AS nomor_nota_beli,\n    toDateTimeOrNull(date_order) AS tanggal_transaksi,\n    toFloat64OrNull(amount_total) AS total_belanja,\n    state AS status_transaksi\n\nFROM raw_purchase\nWHERE id IS NOT NULL AND id != ''", "relation_name": "`kba_silver`.`silver_purchase`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-25T13:16:55.178006Z", "completed_at": "2026-04-25T13:16:55.210478Z"}, {"name": "execute", "started_at": "2026-04-25T13:16:55.217002Z", "completed_at": "2026-04-25T13:16:55.628431Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.4545457363128662, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.kba_kelompok_7.silver_sales", "compiled": true, "compiled_code": "\n\nWITH raw_sales AS (\n    -- Ambil data mentah dari Layer Bronze\n    SELECT * FROM kba_bronze.sale_order\n)\n\nSELECT\n    -- 1. Mengembalikan tipe data ke aslinya\n    toInt32OrNull(id) AS id_penjualan,\n    \n    -- 2. Merapikan nama kolom\n    name AS nomor_nota,\n    \n    -- 3. Mengubah string menjadi format waktu (DateTime)\n    toDateTimeOrNull(date_order) AS tanggal_transaksi,\n    \n    -- 4. Mengubah string menjadi angka desimal (Uang)\n    toFloat64OrNull(amount_total) AS total_belanja,\n    \n    state AS status_transaksi\n\nFROM raw_sales\n-- 5. Membuang baris yang ID-nya kosong/cacat\nWHERE id IS NOT NULL AND id != ''", "relation_name": "`kba_silver`.`silver_sales`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-25T13:16:55.643378Z", "completed_at": "2026-04-25T13:16:55.659609Z"}, {"name": "execute", "started_at": "2026-04-25T13:16:55.661656Z", "completed_at": "2026-04-25T13:16:55.922026Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.28131794929504395, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.kba_kelompok_7.silver_target_penjualan", "compiled": true, "compiled_code": "\n\nWITH raw_target AS (\n    SELECT * FROM kba_bronze.target_penjualan\n)\n\nSELECT\n    -- Ubah teks jadi format Tanggal\n    toDateOrNull(month) AS periode_bulan,\n    \n    -- Ubah teks jadi angka desimal\n    toFloat64OrNull(target_sales) AS target_penjualan\n\nFROM raw_target\nWHERE month IS NOT NULL AND month != ''", "relation_name": "`kba_silver`.`silver_target_penjualan`", "batch_results": null}], "elapsed_time": 5.367686033248901, "args": {"populate_cache": true, "log_format_file": "debug", "select": [], "partial_parse": true, "empty": false, "log_format": "default", "send_anonymous_usage_stats": true, "static_parser": true, "sqlparse": {"MAX_GROUPING_DEPTH": null, "MAX_GROUPING_TOKENS": null}, "quiet": false, "which": "run", "require_explicit_package_overrides_for_builtin_materializations": true, "require_ref_searches_node_package_before_root": false, "require_resource_names_without_spaces": true, "show_all_deprecations": false, "introspect": true, "warn_error_options": {"error": [], "warn": [], "silence": []}, "project_dir": "D:\\naufal\\kba_kelompok_7\\etl_kba", "require_nested_cumulative_type_params": false, "validate_macro_args": false, "state_modified_compare_more_unrendered_valu