umlah_stok\n\nFROM raw_inventory\nWHERE id IS NOT NULL AND id != ''", "relation_name": "`kba_silver`.`silver_inventory`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-26T06:27:39.739894Z", "completed_at": "2026-04-26T06:27:39.741968Z"}, {"name": "execute", "started_at": "2026-04-26T06:27:39.742558Z", "completed_at": "2026-04-26T06:27:39.896059Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.15708065032958984, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.kba_kelompok_7.silver_purchase", "compiled": true, "compiled_code": "\n\nWITH raw_purchase AS (\n    SELECT * FROM kba_bronze.purchase_order\n)\n\nSELECT\n    toInt32OrNull(id) AS id_pembelian,\n    name AS nomor_nota_beli,\n    toDateTimeOrNull(date_order) AS tanggal_transaksi,\n    toFloat64OrNull(amount_total) AS total_belanja,\n    state AS status_transaksi\n\nFROM raw_purchase\nWHERE id IS NOT NULL AND id != ''", "relation_name": "`kba_silver`.`silver_purchase`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-26T06:27:39.899796Z", "completed_at": "2026-04-26T06:27:39.902195Z"}, {"name": "execute", "started_at": "2026-04-26T06:27:39.902465Z", "completed_at": "2026-04-26T06:27:40.058995Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.1601097583770752, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.kba_kelompok_7.silver_sales", "compiled": true, "compiled_code": "\n\nWITH raw_sales AS (\n    -- Ambil data mentah dari Layer Bronze\n    SELECT * FROM kba_bronze.sale_order\n)\n\nSELECT\n    -- 1. Mengembalikan tipe data ke aslinya\n    toInt32OrNull(id) AS id_penjualan,\n    \n    -- 2. Merapikan nama kolom\n    name AS nomor_nota,\n    \n    -- 3. Mengubah string menjadi format waktu (DateTime)\n    toDateTimeOrNull(date_order) AS tanggal_transaksi,\n    \n    -- 4. Mengubah string menjadi angka desimal (Uang)\n    toFloat64OrNull(amount_total) AS total_belanja,\n    \n    state AS status_transaksi\n\nFROM raw_sales\n-- 5. Membuang baris yang ID-nya kosong/cacat\nWHERE id IS NOT NULL AND id != ''", "relation_name": "`kba_silver`.`silver_sales`", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-04-26T06:27:40.063352Z", "completed_at": "2026-04-26T06:27:40.066924Z"}, {"name": "execute", "started_at": "2026-04-26T06:27:40.067365Z", "completed_at": "2026-04-26T06:27:40.223638Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.16100239753723145, "adapter_response": {"_message": "OK"}, "message": "OK", "failures": null, "unique_id": "model.kba_kelompok_7.silver_target_penjualan", "compiled": true, "compiled_code": "\n\nWITH raw_target AS (\n    SELECT * FROM kba_bronze.target_penjualan\n)\n\nSELECT\n    -- Ubah teks jadi format Tanggal\n    toDateOrNull(month) AS periode_bulan,\n    \n    -- Ubah teks jadi angka desimal\n    toFloat64OrNull(target_sales) AS target_penjualan\n\nFROM raw_target\nWHERE month IS NOT NULL AND month != ''", "relation_name": "`kba_silver`.`silver_target_penjualan`", "batch_results": null}], "elapsed_time": 4.735179424285889, "args": {"require_nested_cumulative_type_params": false, "introspect": true, "partial_parse_file_diff": true, "partial_parse": true, "require_batched_execution_for_custom_microbatch_strategy": false, "show_resource_report": false, "select": [], "favor_state": false, "state_modified_compare_more_unrendered_values": false, "show_all_deprecations": false, "require_yaml_configuration_for_mf_time_spines": false, "upload_to_artifacts_ingest_api": false, "use_colors": true, "warn_error_options": {"error": [], "warn": [], "silence": []}, "which": "run", "printer_width": 80, "print": true, "skip_nodes_if_on_run_start_fails": false, "log_level": "info", "require_explicit_package_overrides_for_builtin_materializations": true, "log_format_file": "debug", "quiet": false,